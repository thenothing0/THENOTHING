# ════════════════════════════════════════════════
#  HYDRA — Environment Configuration
#  Copy this to .env and fill in your values
# ════════════════════════════════════════════════

# ── AI Providers ─────────────────────────────
# At least one provider should be configured for AI features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Local Ollama (runs on host machine)
OLLAMA_ENABLED=true
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Custom OpenAI-compatible API
CUSTOM_LLM_URL=
CUSTOM_LLM_KEY=
CUSTOM_LLM_MODEL=

# ── Infrastructure ───────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=hydra
POSTGRES_PASSWORD=hydra_secret
POSTGRES_DB=hydra

# ── MCP Server ───────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8900
MCP_TOOL_TIMEOUT=120
MCP_MAX_CONCURRENT=5

# ── Swarm ────────────────────────────────────
SWARM_MAX_AGENTS=10
SWARM_AGENT_TIMEOUT=300
WORKER_REPLICAS=2

# ── Distributed Mode ────────────────────────
HYDRA_DISTRIBUTED=false
HYDRA_NODE_ID=node-0
HYDRA_NODE_ROLE=all

# ── Security API Keys (optional) ────────────
SHODAN_API_KEY=
VT_API_KEY=
ST_API_KEY=
GITHUB_TOKEN=
CENSYS_ID=
CENSYS_SECRET=
